# ============================================================
#  learn-codex 配置（全部可选）
#
#  默认 backend=mock：无需任何 key、无需联网就能跑通所有章节的回合循环。
#  想体验真 Codex 线协议时，填 OPENAI_API_KEY 即可自动切到 openai 后端。
# ============================================================

# 强制选择后端：mock | openai（留空 = 有 key 自动用 openai，否则 mock）
# CODEX_BACKEND=mock

# 真后端：OpenAI Responses API（这是 Codex 真实使用的协议）
# OPENAI_API_KEY=sk-...
MODEL_ID=gpt-5-codex

# 可选：指向 OpenAI 兼容网关（需支持 /v1/responses）
# OPENAI_BASE_URL=https://api.openai.com/v1
